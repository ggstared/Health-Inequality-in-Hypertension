library(msm)
library(arrow)
library(dplyr)
library(ggplot2)
# =========================
# 2. 数据整理
# =========================
df_states <- df_states %>%
arrange(`身份证号`, time) %>%
mutate(
state = as.integer(state),
time_years = as.numeric(time_years),
payment = as.factor(payment),
gender = as.factor(gender)
)
# 支付方式
df_states$payment <- relevel(df_states$payment, ref = "SP")
# 年龄
df_states$age10 <- df_states$age / 10
# 性别
df_states$gender <- factor(df_states$gender, levels = c(0, 1))
# =========================
# 5. 基础模型
# =========================
msm_base <- msm(
state ~ time_years,
subject = `身份证号`,
data = df_states,
qmatrix = Q_init,
gen.inits = FALSE,
control = list(fnscale = 4000, maxit = 1000, trace = 1)
)
# =========================
# 4. 定义初始 Q 矩阵
# =========================
Q_init <- rbind(
c(0, 0.10, 0.10, 0.05, 0),
c(0, 0,    0,    0,    0.10),
c(0, 0,    0,    0,    0.10),
c(0, 0,    0,    0,    0.10),
c(0, 0,    0,    0,    0)
)
rownames(Q_init) <- colnames(Q_init) <- c("State1", "State2", "State3", "State4", "State5")
Q_init
# =========================
# 5. 基础模型
# =========================
msm_base <- msm(
state ~ time_years,
subject = `身份证号`,
data = df_states,
qmatrix = Q_init,
gen.inits = FALSE,
control = list(fnscale = 4000, maxit = 1000, trace = 1)
)
msm_base
msm_pay <- msm(
state ~ time_years,
subject = `身份证号`,
data = df_states,
qmatrix = Q_init,
covariates = ~ payment,
gen.inits = FALSE,
control = list(fnscale = 4000, maxit = 2000, trace = 1, reltol = 1e-10)
)
